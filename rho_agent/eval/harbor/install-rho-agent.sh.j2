#!/bin/bash
set -euo pipefail

echo "Installing rho-agent..."

# Install system dependencies
apt-get update
apt-get install -y curl git python3 python3-venv

# Install uv if not available
if ! command -v uv &> /dev/null; then
    echo "Installing uv..."
    curl -LsSf https://astral.sh/uv/install.sh | sh
fi

# Add uv to PATH for current session
export PATH="$HOME/.local/bin:$PATH"

VENV_PATH="{{ venv_path }}"
rm -rf "${VENV_PATH}"
uv venv "${VENV_PATH}"

if [ "{{ install_source }}" = "git" ]; then
    echo "Installing rho-agent from git checkout..."
    rm -rf /rho-agent-src
    git clone {{ repo_url }} /rho-agent-src
    cd /rho-agent-src
{% if version %}
    echo "Checking out git ref: {{ version }}"
    git checkout {{ version }}
{% endif %}
    uv pip install --python "${VENV_PATH}/bin/python" ".[evals]"
else
    echo "Installing rho-agent from PyPI..."
{% if version %}
    uv pip install --python "${VENV_PATH}/bin/python" "rho-agent[evals]=={{ version }}"
{% else %}
    uv pip install --python "${VENV_PATH}/bin/python" "rho-agent[evals]"
{% endif %}
fi

echo "rho-agent installation complete!"
